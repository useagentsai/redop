{
  "name": "@useagents/redop",
  "version": "0.1.4",
  "description": "Bun-native MCP server framework",
  "keywords": [
    "bun",
    "framework",
    "mcp",
    "model-context-protocol",
    "typescript"
  ],
  "homepage": "https://redop.useagents.site",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && bun build ./src/index.ts --outdir ./dist --target node && tsc -p tsconfig.build.json",
    "build:js": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build && bun test"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
}
