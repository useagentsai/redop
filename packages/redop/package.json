{
  "name": "@useagents/redop",
  "version": "0.1.6",
  "description": "Bun-native MCP server framework",
  "keywords": [
    "bun",
    "framework",
    "mcp",
    "model-context-protocol",
    "typescript"
  ],
  "homepage": "https://redop.useagents.site",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && bun run ./scripts/build.ts && tsc -p tsconfig.build.json",
    "build:js": "bun run clean && bun run ./scripts/build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {},
  "peerDependenciesMeta": {}
}
