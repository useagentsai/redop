{
  "name": "create-redop-app",
  "version": "0.1.5",
  "description": "Scaffold a Bun-first Redop app",
  "keywords": [
    "bun",
    "cli",
    "mcp",
    "redop",
    "scaffold"
  ],
  "homepage": "https://redop.useagents.site",

  "repository": {
    "type": "git",
    "url": "https://github.com/redopjs/redop.git"
  },
  "bugs": {
    "url": "https://github.com/redopjs/redop/issues"
  },
  "author": {
    "name": "Evans Maina",
    "url": "https://github.com/evansso"
  },
  "license": "MIT",
  "bin": {
    "create-redop-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "bun run clean && bun run ./scripts/build.ts && tsc -p tsconfig.build.json",
    "build:js": "bun run clean && bun run ./scripts/build.ts",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "bun run build && bun test && bun run typecheck",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "ora": "^9.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.4.0"
  }
}
